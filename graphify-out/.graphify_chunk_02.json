{"nodes":[{"id":"release_desktop_workflow","label":"Release Desktop CI Workflow","file_type":"code","source_file":".github/workflows/release-desktop.yml","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null},{"id":"desktop_context","label":"Desktop Collection Context","file_type":"document","source_file":"desktop/CONTEXT.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null},{"id":"api_doc","label":"Heartbeat API Documentation","file_type":"document","source_file":"docs/api.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null},{"id":"db_doc","label":"Heartbeat Database Design","file_type":"document","source_file":"docs/db.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null},{"id":"multi_user_plan","label":"Multi-User Conversion Plan","file_type":"document","source_file":"docs/multi-user-plan.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null},{"id":"adr001_server_side_usage_merging","label":"ADR-001: Server-Side Usage Merging","file_type":"rationale","source_file":"docs/adr/001-server-side-usage-merging.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Dual-layer merging (client + server) ensures data consistency even on agent crash/duplicate upload. Composite index (DeviceId, AppId, EndTime) keeps merge-lookup fast. Trade-off: extra DB read per upload batch."},{"id":"adr002_event_driven_window_tracking","label":"ADR-002: Event-Driven Window Tracking","file_type":"rationale","source_file":"docs/adr/002-event-driven-window-tracking.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"WinEvent hooks replace polling for zero CPU idle cost and no missed transitions. Trade-off: dedicated thread with Win32 message pump, platform-locked to Windows."},{"id":"adr003_generic_host_lifecycle","label":"ADR-003: Generic Host Lifecycle","file_type":"rationale","source_file":"docs/adr/003-generic-host-lifecycle.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Adopted .NET Generic Host for DI, IHostedService lifecycle, and graceful shutdown (flushing pending uploads). Trade-off: heavier startup for originally simple console app."},{"id":"adr004_apikey_header_auth","label":"ADR-004: ApiKey Header Authentication","file_type":"rationale","source_file":"docs/adr/004-apikey-header-authentication.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Custom AuthenticationHandler reads ApiKey from Authorization header instead of DTO body. Enables [Authorize] attribute and centralized auth. Trade-off: DB query per authenticated request, plaintext over HTTPS."},{"id":"adr005_extract_agent_library","label":"ADR-005: Extract Agent Library","file_type":"rationale","source_file":"docs/adr/005-extract-agent-library.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Extracted Heartbeat.Agent as reusable class library shared by Console Runner and WPF host via AddHeartbeatAgent(). Trade-off: ConfigManager injection API complexity, net10.0-windows target not portable."},{"id":"adr006_dedicated_report_endpoints","label":"ADR-006: Dedicated Report Endpoints","file_type":"rationale","source_file":"docs/adr/006-dedicated-report-endpoints.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Server-side SQL aggregation via ReportController replaces client-side data processing. Trade-off: two query paths (raw + aggregated) must stay in sync."},{"id":"adr007_disable_prod_auto_migration","label":"ADR-007: Disable Prod Auto-Migration","file_type":"rationale","source_file":"docs/adr/007-disable-prod-auto-migration.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Auto-migration guarded by IsDevelopment() check. Production requires explicit dotnet ef database update. Trade-off: risk of forgetting to run migrations on deploy."},{"id":"adr008_local_cache_offline_retry","label":"ADR-008: Local Cache Offline Retry","file_type":"rationale","source_file":"docs/adr/008-local-cache-offline-retry.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Local JSON file cache buffers failed uploads with 10K record cap, atomic rename writes, and ReaderWriterLockSlim. Survives agent restarts. Deduplication handled by server-side merge (ADR-001)."},{"id":"adr009_velopack_auto_update","label":"ADR-009: Velopack Auto-Update","file_type":"rationale","source_file":"docs/adr/009-velopack-auto-update.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Chose Velopack (Squirrel successor) for .NET-native auto-update with GitHub Releases integration and delta updates. VelopackApp.Build().Run() must be earliest call in Main."},{"id":"adr010_per_user_localappdata","label":"ADR-010: Per-User LocalAppData Install","file_type":"rationale","source_file":"docs/adr/010-per-user-localappdata-install.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Install to %LocalAppData%\\Heartbeat for UAC-free install/update. Trade-off: multi-user machines need separate installs, no custom path (Velopack limitation)."},{"id":"adr011_github_releases_update_source","label":"ADR-011: GitHub Releases Update Source","file_type":"rationale","source_file":"docs/adr/011-github-releases-update-source.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Hardcoded GitHub Releases URL as update source to avoid CDN/infrastructure cost. Trade-off: China users may have download issues; switching requires transitional release."},{"id":"domain_doc","label":"Agent Domain Documentation Guide","file_type":"document","source_file":"docs/agents/domain.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null},{"id":"issue_tracker_doc","label":"Local Markdown Issue Tracker","file_type":"document","source_file":"docs/agents/issue-tracker.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null},{"id":"triage_labels_doc","label":"Triage Labels Vocabulary","file_type":"document","source_file":"docs/agents/triage-labels.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null},{"id":"frontend_index","label":"Frontend Entry HTML","file_type":"code","source_file":"frontend/index.html","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null},{"id":"server_readme","label":"Server EF Core Migrations Guide","file_type":"document","source_file":"server/Heartbeat.Server/README.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null},{"id":"shared_context","label":"Shared Kernel Context","file_type":"document","source_file":"shared/CONTEXT.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null},{"id":"concept_device","label":"Device (Domain Entity)","file_type":"rationale","source_file":"shared/CONTEXT.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Physical machine identified by (OwnerId, HardwareId). HardwareId from Windows MachineGuid. DeviceName is display-only (default hostname, user-editable). Belongs to a User."},{"id":"concept_app","label":"App (Domain Entity)","file_type":"rationale","source_file":"shared/CONTEXT.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Application identified by process executable filename (no path). Multiple windows of same exe = same App."},{"id":"concept_app_usage","label":"AppUsage (Domain Entity)","file_type":"rationale","source_file":"shared/CONTEXT.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Time record of an App being in the foreground (StartTime->EndTime). Includes all foreground windows (explorer.exe, LockApp.exe) without active/inactive filtering."},{"id":"concept_usage_merger","label":"UsageMerger (Domain Mechanism)","file_type":"rationale","source_file":"shared/CONTEXT.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Merges fragmented records from upload batching. Rule: same AppName + gap <=1s -> merge. Dual-layer execution (client + server). Does NOT merge cross-switch records."},{"id":"concept_apikey","label":"ApiKey (Auth Credential)","file_type":"rationale","source_file":"shared/CONTEXT.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Credential for Collection (Agent) to upload data to Analytics, analogous to LLM API Key."},{"id":"concept_agent","label":"Agent (Desktop Collection Engine)","file_type":"rationale","source_file":"desktop/CONTEXT.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Background collection engine responsible for window switch monitoring, usage record generation, caching, and uploading. Avoid calling it Service or Worker (those are internal implementation layers)."},{"id":"concept_velopack","label":"Velopack (Update Framework)","file_type":"rationale","source_file":"docs/adr/009-velopack-auto-update.md","source_location":null,"source_url":null,"captured_at":null,"author":null,"contributor":null,"rationale":"Squirrel.Windows successor for .NET desktop auto-update. Manages install/update/uninstall lifecycle, supports delta updates and GitHub Releases integration."}],"edges":[{"source":"adr001_server_side_usage_merging","target":"concept_usage_merger","relation":"rationale_for","confidence":"EXTRACTED","confidence_score":1.0,"source_file":"docs/adr/001-server-side-usage-merging.md","source_location":null,"weight":1.0},{"source":"adr001_server_side_usage_merging","target":"concept_app_usage","relation":"references","confidence":"EXTRACTED","confidence_score":1.0,"source_file":"docs/adr/001-server-side-usage-merging.md","source_location":null,"weight":1.0},{"source":"adr002_event_driven_window_tracking","target":"concept_agent","relation":"rationale_for","confidence":"EXTRACTED","confidence_score":1.0,"source_file":"docs/adr/002-event-driven-window-tracking.md","source_location":null,"weight":1.0},{"source":"adr003_generic_host_lifecycle","target":"concept_agent","relation":"rationale_for","confidence":"EXTRACTED","confidence_score":1.0,"source_file":"docs/adr/003-generic-host-lifecycle.md","source_location":null,"weight":1.0},{"source":"adr003_generic_host_lifecycle","target":"adr005_extract_agent_library","relation":"references","confidence":"EXTRACTED","confidence_score":1.0,"source_file":"docs/adr/003-generic-host-lifecycle.md","source_location":"line 30","weight":0.8},{"source":"adr004_apikey_header_auth","target":"concept_apikey","relation":"rationale_for","confidence":"EXTRACTED","confidence_score":1.0,"source_file":"docs/adr/004-apikey-header-authentication.md","source_location":null,"weight":1.0},{"source":"adr005_extract_agent_library","target":"concept_agent","relation":"rationale_for","confidence":"EXTRACTED","confidence_score":1.0,"source_file":"docs/adr/005-extract-agent-library.md","source_location":null,"weight":1.0},{"source":"adr005_extract_agent_library","target":"adr003_generic_host_lifecycle","relation":"references","confidence":"EXTRACTED","confidence_score":1.0,"source_file":"docs/adr/005-extract-agent-library.md","source_location":"line 30","weight":0.8},{"source":"ad