<Window x:Class="Heartbeat.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Heartbeat" Height="480" Width="720"
        Icon="heartbeat.ico"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="NavButtonStyle" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Width="40" Height="40" Margin="4,2"
                                CornerRadius="6" Background="Transparent">
                            <TextBlock Text="{TemplateBinding Content}"
                                       FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                       FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Window}}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="48"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 侧边栏导航 -->
        <Border Grid.Column="0" BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}" BorderThickness="0,0,1,0">
            <StackPanel VerticalAlignment="Top" Margin="0,8,0,0">
                <RadioButton x:Name="NavStatus" IsChecked="True" Style="{StaticResource NavButtonStyle}"
                             Content="&#xE9D9;" ToolTip="状态"/>
                <RadioButton x:Name="NavCollectors" Style="{StaticResource NavButtonStyle}"
                             Content="&#xEA86;" ToolTip="采集器"/>
                <RadioButton x:Name="NavSettings" Style="{StaticResource NavButtonStyle}"
                             Content="&#xE713;" ToolTip="设置"/>
            </StackPanel>
        </Border>

        <!-- 内容区 -->
        <Grid Grid.Column="1" Margin="20">

            <!-- 页面1: 状态 + 日志 -->
            <Grid Visibility="{Binding IsChecked, ElementName=NavStatus, Converter={StaticResource BoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,16">
                    <TextBlock Text="当前状态" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,12"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="前台应用：" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding CurrentApp}" Foreground="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}"
                                   FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="运行日志" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <Button Content="DBG" Padding="6,2" Margin="0,0,4,0" Command="{Binding SetLogLevelCommand}" CommandParameter="Debug"/>
                        <Button Content="INF" Padding="6,2" Margin="0,0,4,0" Command="{Binding SetLogLevelCommand}" CommandParameter="Information"/>
                        <Button Content="WRN" Padding="6,2" Margin="0,0,4,0" Command="{Binding SetLogLevelCommand}" CommandParameter="Warning"/>
                        <Button Content="ERR" Padding="6,2" Command="{Binding SetLogLevelCommand}" CommandParameter="Error"/>
                    </StackPanel>
                    <TextBox x:Name="LogTextBox" Grid.Row="1"
                             Text="{Binding LogText, Mode=OneWay}"
                             IsReadOnly="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             TextWrapping="NoWrap"
                             FontFamily="Consolas"
                             FontSize="11"
                             Padding="8"
                             TextChanged="LogTextBox_TextChanged"/>
                </Grid>
            </Grid>

            <!-- 页面2: 采集器（ADR-026 §5：可管理性分级——plugin 带开关，system 只读） -->
            <Grid Visibility="{Binding IsChecked, ElementName=NavCollectors, Converter={StaticResource BoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="采集器" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Collectors}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource SettingsCardStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- 前导图标 -->
                                        <TextBlock Grid.Column="0" Text="{Binding IconGlyph}"
                                                   FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                                   FontSize="20" VerticalAlignment="Center" Margin="0,0,16,0"/>

                                        <!-- 标题 + 副标题 -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Source}" FontSize="14"/>
                                                <Border Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                                                        CornerRadius="4" Padding="6,1" Margin="8,0,0,0" VerticalAlignment="Center"
                                                        Visibility="{Binding IsSystem, Converter={StaticResource BoolToVis}}">
                                                    <TextBlock Text="内置" FontSize="11"
                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Description}" FontSize="12" Margin="0,2,0,0"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                <Ellipse Width="8" Height="8" VerticalAlignment="Center">
                                                    <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                            <Setter Property="Fill" Value="{DynamicResource TextFillColorTertiaryBrush}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                    <Setter Property="Fill" Value="{DynamicResource SystemFillColorSuccessBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Ellipse.Style>
                                                </Ellipse>
                                                <TextBlock Margin="6,0,0,0" FontSize="12" VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="不活跃"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                    <Setter Property="Text" Value="活跃"/>
                                                                    <Setter Property="Foreground" Value="{DynamicResource SystemFillColorSuccessBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- 开关只对 plugin 渲染；system 不可停用，无开关（非置灰） -->
                                        <CheckBox Grid.Column="2" Content="启用" VerticalAlignment="Center" Margin="12,0,0,0"
                                                  IsChecked="{Binding Enabled}"
                                                  Visibility="{Binding CanToggle, Converter={StaticResource BoolToVis}}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- 页面3: 设置（每项一张 SettingsCard：图标 | 标题+说明 | 控件） -->
            <Grid Visibility="{Binding IsChecked, ElementName=NavSettings, Converter={StaticResource BoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="设置" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- API Key -->
                        <Border Style="{StaticResource SettingsCardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="&#xE8D7;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                           FontSize="20" VerticalAlignment="Center" Margin="0,0,16,0"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="API Key" FontSize="14"/>
                                    <TextBlock Text="上传数据到服务端的访问凭证" FontSize="12" Margin="0,2,0,0"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>
                                <TextBox Grid.Column="2" Width="240" VerticalAlignment="Center" Margin="16,0,0,0"
                                         Text="{Binding ApiKey, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>
                        </Border>

                        <!-- 设备名称 -->
                        <Border Style="{StaticResource SettingsCardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="&#xE7F4;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                           FontSize="20" VerticalAlignment="Center" Margin="0,0,16,0"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="设备名称" FontSize="14"/>
                                    <TextBlock Text="此设备在报表中显示的名字" FontSize="12" Margin="0,2,0,0"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>
                                <TextBox Grid.Column="2" Width="240" VerticalAlignment="Center" Margin="16,0,0,0"
                                         Text="{Binding DeviceName, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>
                        </Border>

                        <!-- 上传间隔 -->
                        <Border Style="{StaticResource SettingsCardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="&#xE895;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                           FontSize="20" VerticalAlignment="Center" Margin="0,0,16,0"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="上传间隔" FontSize="14"/>
                                    <TextBlock Text="每隔多少分钟向服务端上传一次" FontSize="12" Margin="0,2,0,0"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>
                                <TextBox Grid.Column="2" Width="80" VerticalAlignment="Center" Margin="16,0,0,0"
                                         Text="{Binding UploadIntervalMinutes, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>
                        </Border>

                        <!-- 开机自启动 -->
                        <Border Style="{StaticResource SettingsCardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="&#xE7E8;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                           FontSize="20" VerticalAlignment="Center" Margin="0,0,16,0"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="开机自启动" FontSize="14"/>
                                    <TextBlock Text="登录 Windows 后自动开始采集" FontSize="12" Margin="0,2,0,0"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>
                                <CheckBox Grid.Column="2" VerticalAlignment="Center" Margin="16,0,0,0"
                                          IsChecked="{Binding AutoStartEnabled}"/>
                            </Grid>
                        </Border>

                        <!-- 保存 + 状态 -->
                        <Grid Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding SaveStatusMessage}" VerticalAlignment="Center"
                                       Visibility="{Binding SaveStatusVisible, Converter={StaticResource BoolToVis}}"
                                       FontSize="12" Margin="2,0,12,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource SystemFillColorSuccessBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SaveStatusIsError}" Value="True">
                                                <Setter Property="Foreground" Value="{DynamicResource SystemFillColorCriticalBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <Button Grid.Column="1" Content="保存配置" Style="{DynamicResource AccentButtonStyle}"
                                    Padding="16,8" Command="{Binding SaveConfigCommand}"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Window>