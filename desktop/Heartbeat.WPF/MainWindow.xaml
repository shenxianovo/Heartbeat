<Window x:Class="Heartbeat.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Heartbeat.WPF.ViewModels"
        mc:Ignorable="d"
        Title="Heartbeat" Height="480" Width="720"
        Icon="heartbeat.ico"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="NavButtonStyle" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Width="40" Height="40" Margin="4,2"
                                CornerRadius="6" Background="Transparent">
                            <TextBlock Text="{TemplateBinding Content}"
                                       FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                       FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Window}}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#20808080"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#30808080"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="48"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 侧边栏导航 -->
        <Border Grid.Column="0" BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}" BorderThickness="0,0,1,0">
            <StackPanel VerticalAlignment="Top" Margin="0,8,0,0">
                <RadioButton x:Name="NavStatus" IsChecked="True" Style="{StaticResource NavButtonStyle}"
                             Content="&#xE9D9;" ToolTip="状态"/>
                <RadioButton x:Name="NavSettings" Style="{StaticResource NavButtonStyle}"
                             Content="&#xE713;" ToolTip="设置"/>
            </StackPanel>
        </Border>

        <!-- 内容区 -->
        <Grid Grid.Column="1" Margin="20">

            <!-- 页面1: 状态 + 日志 -->
            <Grid Visibility="{Binding IsChecked, ElementName=NavStatus, Converter={StaticResource BoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,16">
                    <TextBlock Text="当前状态" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,12"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="前台应用：" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding CurrentApp}" Foreground="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}"
                                   FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="运行日志" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBox x:Name="LogTextBox" Grid.Row="1"
                             Text="{Binding LogText, Mode=OneWay}"
                             IsReadOnly="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             TextWrapping="NoWrap"
                             FontFamily="Consolas"
                             FontSize="11"
                             Padding="8"
                             TextChanged="LogTextBox_TextChanged"/>
                </Grid>
            </Grid>

            <!-- 页面2: 设置 -->
            <Grid Visibility="{Binding IsChecked, ElementName=NavSettings, Converter={StaticResource BoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="设置" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16"/>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="API Base URL" VerticalAlignment="Center" Margin="0,0,16,12"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding ApiBaseUrl, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="AuthService URL" VerticalAlignment="Center" Margin="0,0,16,12"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding AuthServiceBaseUrl, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="API Key" VerticalAlignment="Center" Margin="0,0,16,12"/>
                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding ApiKey, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="设备名称" VerticalAlignment="Center" Margin="0,0,16,12"/>
                    <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding DeviceName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="上传间隔 (分钟)" VerticalAlignment="Center" Margin="0,0,16,12"/>
                    <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding UploadIntervalMinutes, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="状态间隔 (秒)" VerticalAlignment="Center" Margin="0,0,16,12"/>
                    <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding StatusUploadIntervalSeconds, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                    <CheckBox Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" Content="开机自启动"
                              IsChecked="{Binding AutoStartEnabled}" Margin="0,4,0,12"/>

                    <Button Grid.Row="7" Grid.Column="1" Content="保存配置"
                            HorizontalAlignment="Right" Padding="16,8"
                            Command="{Binding SaveConfigCommand}"/>
                </Grid>

                <TextBlock Grid.Row="2" Text="{Binding SaveStatusMessage}" Margin="0,12,0,0"
                           Visibility="{Binding SaveStatusVisible, Converter={StaticResource BoolToVis}}"
                           FontSize="12">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="Green"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SaveStatusIsError}" Value="True">
                                    <Setter Property="Foreground" Value="Red"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </Grid>
    </Grid>
</Window>