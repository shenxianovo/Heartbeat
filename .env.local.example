# 本地端到端验证用（compose.local.yml）。复制为 .env.local 填入真实值。
# .env.local 已被 .gitignore 忽略，不会提交。
#
# 鉴权走路径甲：本地 backend 用你线上真实 Auth 平台校验 JWT，
# 因此这里填线上 Auth 平台的地址即可（通常就是默认值）。

AUTH_AUTHORITY=https://auth.shenxianovo.com
# 会话 JWT（Agent 走 apikeys/exchange）——不带尾斜杠
AUTH_ISSUER=https://auth.shenxianovo.com
AUTH_AUDIENCE=https://auth.shenxianovo.com
# OIDC access token（Web 登录）——issuer 带尾斜杠，须与 discovery 文档完全一致
AUTH_OIDC_ISSUER=https://auth.shenxianovo.com/
AUTH_OIDC_CLIENT_ID=heartbeat-web
# 留空：上游未注册 resource，OIDC 令牌无 aud，后端以 client_id 校验代替
AUTH_OIDC_AUDIENCE=

# Recap LLM（可选：不填则 /recaps/daily 返回 502"未配置"，其余功能不受影响）
RECAP_API_KEY=
