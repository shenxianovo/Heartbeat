{
  "manifest_version": 3,
  "name": "Heartbeat Browser Collector",
  "version": "0.1.0",
  "description": "Collects active-tab activity into the local Heartbeat ingest hub.",
  "minimum_chrome_version": "120",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "permissions": ["tabs", "storage", "alarms"],
  "host_permissions": ["http://127.0.0.1/*"]
}
